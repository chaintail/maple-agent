{
  "name": "maple-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Budget-capped AI agent spending demo using Solana Native Allowances concepts.",
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "concurrently -n web,agent,tools,indexer -c auto \"npm run dev -w @maple-agent/web\" \"npm run dev -w @maple-agent/agent-api\" \"npm run dev -w @maple-agent/tool-market\" \"npm run dev -w @maple-agent/indexer\"",
    "dev:web": "npm run dev -w @maple-agent/web",
    "dev:api": "npm run dev -w @maple-agent/agent-api",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "demo:setup": "tsx scripts/setup-local-demo.ts",
    "demo:run": "tsx scripts/run-agent.ts",
    "demo:revoke": "tsx scripts/revoke.ts",
    "demo:try-spend-after-revoke": "tsx scripts/try-spend-after-revoke.ts",
    "demo:reset": "tsx scripts/reset-demo.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
