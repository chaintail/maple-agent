# Shared demo state file. Leave blank to use ./.maple-agent/state.json from the repo root.
MAPLE_AGENT_STATE_PATH=

# App ports
PORT=3001
TOOL_MARKET_PORT=3002
INDEXER_PORT=3003
VITE_AGENT_API_URL=http://localhost:3001

# Demo chain mode. The included demo defaults to a deterministic local ledger.
# Swap this to "sdk" once you wire packages/solana to @solana/subscriptions for devnet/localnet.
SOLANA_ALLOWANCE_MODE=mock

# Optional Solana RPC values for the production adapter skeleton.
SOLANA_RPC_URL=http://localhost:8899
SOLANA_CLUSTER=localnet
