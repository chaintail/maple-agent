# Shared demo state file. Leave blank to use ./.maple-agent/state.json from the repo root.
MAPLE_AGENT_STATE_PATH=

# App ports
PORT=3001
TOOL_MARKET_PORT=3002
INDEXER_PORT=3003
VITE_AGENT_API_URL=http://localhost:3001

# Demo chain mode. The included demo defaults to a deterministic local ledger.
# Use "sdk" for the real @solana/subscriptions devnet adapter.
SOLANA_ALLOWANCE_MODE=mock

# Solana SDK/devnet mode. Keep unset for mock demo mode.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_WS_URL=wss://api.devnet.solana.com
SOLANA_CLUSTER=devnet
SOLANA_DEVNET_KEYPAIR_DIR=.maple-agent-devnet
SOLANA_DEVNET_CONFIG_PATH=.maple-agent-devnet/config.json
SOLANA_DELEGATOR_KEYPAIR_PATH=.maple-agent-devnet/delegator.json
SOLANA_DELEGATEE_KEYPAIR_PATH=.maple-agent-devnet/delegatee.json
SOLANA_TEST_MINT_KEYPAIR_PATH=.maple-agent-devnet/mock-usdc-mint.json
SOLANA_TOKEN_MINT=
SOLANA_TEST_TOKEN_AMOUNT=25
SOLANA_AIRDROP_LAMPORTS=2000000000
